<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Math Test</title>
</head>
<body>

    <h1>Math Test</h1>

    <!-- Start of the test -->
    <form>
        
        <!-- Text field for user's name -->
        <p>
            <label for="name">Student Name:</label><br>
            <input type="text" id="name" name="student_name">
        </p>

        <hr>

        <!-- Multiple choice questions -->
        <h3>Section 1: Multiple Choice</h3>

        <p>1. What is 5 &times; 5?</p>
        <input type="radio" id="q1a" name="q1" value="10">
        <label for="q1a">10</label><br>
        <input type="radio" id="q1b" name="q1" value="25">
        <label for="q1b">25</label><br>
        <input type="radio" id="q1c" name="q1" value="50">
        <label for="q1c">50</label>

        <p>2. Solve for x: 100 &divide; x = 4</p>
        <input type="radio" id="q2a" name="q2" value="20">
        <label for="q2a">20</label><br>
        <input type="radio" id="q2b" name="q2" value="25">
        <label for="q2b">25</label><br>
        <input type="radio" id="q2c" name="q2" value="40">
        <label for="q2c">40</label>

        <p>3. What is the value of &radic;81?</p>
        <input type="radio" id="q3a" name="q3" value="7">
        <label for="q3a">7</label><br>
        <input type="radio" id="q3b" name="q3" value="8">
        <label for="q3b">8</label><br>
        <input type="radio" id="q3c" name="q3" value="9">
        <label for="q3c">9</label>

        <hr>

        <!-- Word problem with multiline textarea -->
        <h3>Section 2: Word Problem</h3>
        <p>
            Word Problem: If a train travels 60 kilometers in 1 hour, how many kilometers it will travel in 3 hours? 
            Please explain your calculation steps:
        </p>
        <textarea id="explanation" name="explanation" rows="4" cols="50"></textarea>

        <br><br>

        <!-- Submit button -->
        <input type="submit" value="Submit Test">

    </form>
    <!-- End of the test -->

</body>
</html>